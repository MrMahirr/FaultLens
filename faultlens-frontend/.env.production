# .env.production
# Bu dosya Next.js uygulaması canlı ortam için derlenirken (build) kullanılır.
# NEXT_PUBLIC_ öneki olan değişkenler frontend tarafında tarayıcıya yansır.

# Gerçek canlı ortam domaininizi aşağıya girin.
# Örnek: https://api.sirketiniz.com/api/v1
NEXT_PUBLIC_API_URL=https://api.faultlens.com/api/v1

# WebSocket bağlantısı için (wss: secure websocket)
# Örnek: wss://api.sirketiniz.com/ws
NEXT_PUBLIC_WS_URL=wss://api.faultlens.com/ws
